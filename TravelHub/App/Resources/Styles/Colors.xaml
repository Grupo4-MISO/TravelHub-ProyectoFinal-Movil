<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- TravelHub Brand Colors -->
    <Color x:Key="Primary">#015C77</Color>
    <Color x:Key="PrimaryDark">#013e50</Color>
    <Color x:Key="PrimaryLight">#017a9e</Color>
    <Color x:Key="Accent">#F06D51</Color>
    <Color x:Key="AccentLight">#FFE0B2</Color>
    <Color x:Key="Background">#F5F5F5</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Star">#FFC107</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Danger">#F44336</Color>
    
    <!-- Dynamic Text Size Resources -->
    <x:Double x:Key="BaseFontSize">14</x:Double>
    <x:Double x:Key="HeadlineFontSize">28</x:Double>
    <x:Double x:Key="SubHeadlineFontSize">20</x:Double>
    <x:Double x:Key="TitleFontSize">18</x:Double>
    <x:Double x:Key="SubtitleFontSize">14</x:Double>
    <x:Double x:Key="CaptionFontSize">14</x:Double>
    <x:Double x:Key="PriceFontSize">20</x:Double>

    <!-- Base Colors -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Transparent">Transparent</Color>

    <!-- Gray Scale -->
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>
