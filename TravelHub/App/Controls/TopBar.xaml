<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App.Controls.TopBar">
    <Grid BackgroundColor="White" Padding="16,12" 
          ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
        <!--<Label Text="TravelHub" 
               HorizontalTextAlignment="Center"
               FontFamily="OpenSansSemibold"
               FontSize="22"
               TextColor="{StaticResource White}"
               VerticalOptions="Center" />-->
        <Image Grid.Column="0" Source="travelhub.png" 
               WidthRequest="120" HeightRequest="25"
               HorizontalOptions="Start"
               Aspect="AspectFit"
               VerticalOptions="Center" />
        <Button Grid.Column="1" 
                CornerRadius="20"
                ImageSource="ic_col.png"
                WidthRequest="20"
                MaximumWidthRequest="30"
                MaximumHeightRequest="30"
                Padding="0"
                BackgroundColor="WhiteSmoke"></Button>
        <Button Grid.Column="2" 
                CornerRadius="20"
                ImageSource="ic_col.png"
                WidthRequest="20"
                MaximumWidthRequest="30"
                MaximumHeightRequest="30"
                Padding="0"
                BackgroundColor="WhiteSmoke"></Button>
        <Button Grid.Column="3" 
                CornerRadius="25"
                WidthRequest="25"
                 MaximumWidthRequest="30"
                  MaximumHeightRequest="30"
                Padding="0"
                ImageSource="ic_notifications.png"
                BackgroundColor="WhiteSmoke"></Button>
    </Grid>
</ContentView>
