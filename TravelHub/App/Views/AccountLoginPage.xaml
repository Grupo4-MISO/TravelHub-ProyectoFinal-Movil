<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.AccountLoginPage"
             AutomationId="Login_Page"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="32" Spacing="20"
                             VerticalOptions="Center">

            <!-- Logo / Titulo -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,40,0,20">
                <Image Source="travelhub.png" Aspect="AspectFill" />
                <!--<Label Text="TravelHub"
                       Style="{StaticResource Headline}"
                       HorizontalTextAlignment="Center" />-->
<Label Text="{local:Translate Login_Titulo}"
       Style="{StaticResource Subtitle}"
       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Formulario -->
            <Border Padding="20"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource Gray100}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,3" Radius="10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Login_Email}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Login_EmailPlaceholder}"
       AutomationId="Login_EmailEntry"
       Text="{Binding Email}"
       Keyboard="Email" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Login_Password}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Login_PasswordPlaceholder}"
       AutomationId="Login_PasswordEntry"
       Text="{Binding Password}"
       IsPassword="True" />
                        </Border>
                    </VerticalStackLayout>

<Button Text="{local:Translate Login_IniciarSesion}"
        AutomationId="Login_LoginButton"
        Command="{Binding LoginCommand}"
        HorizontalOptions="Fill" />

                    <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
<Label Text="{local:Translate Login_NoTienesCuenta}"
       Style="{StaticResource Caption}"
       VerticalTextAlignment="Center" />
<Label Text="{local:Translate Login_Registrate}"
       AutomationId="Login_RegisterLink"
       TextColor="{StaticResource Primary}"
       FontFamily="OpenSansSemibold"
       FontSize="13"
       VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RegisterCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
