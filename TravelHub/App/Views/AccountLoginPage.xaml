<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App.Views.AccountLoginPage"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="32" Spacing="20"
                             VerticalOptions="Center">

            <!-- Logo / Titulo -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,40,0,20">
                <Image Source="travelhub.png" Aspect="AspectFill" />
                <Label Text="TravelHub"
                       Style="{StaticResource Headline}"
                       HorizontalTextAlignment="Center" />
                <Label Text="Inicia sesion para continuar"
                       Style="{StaticResource Subtitle}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Formulario -->
            <Border Padding="20"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource Gray100}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,3" Radius="10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Email" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Entry Placeholder="micorreo@email.com"
                                   Text="{Binding Email}"
                                   Keyboard="Email" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Password" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Entry Placeholder="Mi clave"
                                   Text="{Binding Password}"
                                   IsPassword="True" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Iniciar Sesion"
                            Command="{Binding LoginCommand}"
                            HorizontalOptions="Fill" />

                    <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="No tienes cuenta?"
                               Style="{StaticResource Caption}"
                               VerticalTextAlignment="Center" />
                        <Label Text="Registrate"
                               TextColor="{StaticResource Primary}"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RegisterCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
