<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.AccountPage"
             AutomationId="Account_Page"
             Title="{Binding Title}"
             IconImageSource="ic_account.png"
             Shell.NavBarIsVisible="False">

    <Grid BackgroundColor="{StaticResource Background}">

        <!-- ===== VISTA PERFIL (logueado) ===== -->
        <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsLoggedIn}">

            <!-- Header -->
            <Grid Grid.Row="0" Padding="16,14" BackgroundColor="{StaticResource Primary}">
<Label Text="{local:Translate Account_Titulo}"
       TextColor="{StaticResource White}"
       FontFamily="OpenSansSemibold"
       FontSize="18" />
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16" Spacing="16">

                    <!-- Perfil -->
                    <Border Padding="20"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource Gray100}">
                        <Border.Shadow>
                            <Shadow Brush="#15000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Border HeightRequest="150" WidthRequest="150"
                                    BackgroundColor="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="150"/>
                                </Border.StrokeShape>
                                <Image Source="{Binding User.photo}" Aspect="AspectFill" />
                            </Border>
                            <Label Text="{Binding User.first_name}"
                                   AutomationId="Account_UserName"
                                   FontFamily="OpenSansSemibold" FontSize="20"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Opciones -->
                    <Border Padding="0"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource Gray100}">
                        <VerticalStackLayout>
                            <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                                <Label Text="{local:Translate Account_EditarPerfil}" FontSize="15" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text=">" Style="{StaticResource Caption}"
                                       FontSize="18" VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditProfileCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                            <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                                <Label Text="{local:Translate Account_Historial}" FontSize="15" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text=">" Style="{StaticResource Caption}"
                                       FontSize="18" VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ViewHistoryCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />
                     </VerticalStackLayout>
                    </Border>

                    <!-- Idioma / Language -->
                    <Border Padding="16,14" 
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource Gray100}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{local:Translate Language_Seleccionar}" 
                                   FontSize="15" 
                                   FontFamily="OpenSansSemibold" />
                            <Picker x:Name="LanguagePicker"
                                    AutomationId="Account_LanguagePicker"
                                    SelectedIndexChanged="OnLanguageChanged" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Cerrar Sesion -->
<Button Text="{local:Translate Account_CerrarSesion}"
        AutomationId="Account_LogoutButton"
        Command="{Binding LogoutCommand}"
        BackgroundColor="{StaticResource Primary}"
        TextColor="{StaticResource White}"
        HorizontalOptions="Fill" />

<Label Text="{local:Translate Account_Version}"
       Style="{StaticResource Caption}"
       HorizontalTextAlignment="Center"
       Margin="0,8,0,0" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ===== VISTA LOGIN (no logueado) ===== -->
        <ScrollView IsVisible="{Binding IsNotLoggedIn}">
            <VerticalStackLayout Padding="32" Spacing="20" VerticalOptions="Center">

                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,40,0,20">
                    <Image Source="travelhub.png" Aspect="AspectFill" />
<Label Text="{local:Translate Account_IniciaSesion}"
       Style="{StaticResource Subtitle}"
       HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Border Padding="20"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource Gray100}">
                    <Border.Shadow>
                        <Shadow Brush="#15000000" Offset="0,3" Radius="10" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Account_Email}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Account_EmailPlaceholder}"
       AutomationId="Account_EmailEntry"
       Text="{Binding Email}"
       Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Account_Password}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Account_PasswordPlaceholder}"
       AutomationId="Account_PasswordEntry"
       Text="{Binding Password}"
       IsPassword="True" />
                            </Border>
                        </VerticalStackLayout>

<Button Text="{local:Translate Account_IniciarSesion}"
        AutomationId="Account_LoginButton"
        Command="{Binding LoginCommand}"
        HorizontalOptions="Fill" />

                        <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
<Label Text="{local:Translate Account_NoTienesCuenta}"
       Style="{StaticResource Caption}"
       VerticalTextAlignment="Center" />
<Label Text="{local:Translate Account_Registrate}"
       AutomationId="Account_RegisterLink"
       TextColor="{StaticResource Primary}"
       FontFamily="OpenSansSemibold" FontSize="13"
       VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RegisterCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
