<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.RoomSelectionPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource Background}">

        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Rooms}"
                        Margin="16,12">
            <CollectionView.Header>
                <Label Text="{Binding Property.Name, StringFormat='Habitaciones en {0}'}"
                       Style="{StaticResource SubHeadline}"
                       Margin="0,0,0,12" />
            </CollectionView.Header>
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 14"
                            Stroke="{StaticResource Gray100}"
                            Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="#18000000" Offset="0,2" Radius="8" />
                        </Border.Shadow>
                        <Grid RowDefinitions="160,Auto">
                            <Image Source="{Binding ImageUrl}"
                                   Aspect="AspectFill"
                                   HeightRequest="160" />
                            <VerticalStackLayout Grid.Row="1" Padding="14" Spacing="6">
                                <Label Text="{Binding Description}"
                                       FontFamily="OpenSansSemibold" FontSize="17" />
                                <!--<Label Text="{Binding Description}"
                                       Style="{StaticResource Subtitle}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />-->
                                <VerticalStackLayout Spacing="5">
                                    <HorizontalStackLayout>
                                        <Label Text="{Binding Code}" Style="{StaticResource Caption}" />
                                        <Label Text="|" Style="{StaticResource Caption}" />
                                        <Label Text="{Binding Capacity, StringFormat='Max {0} huespedes'}"
                                               Style="{StaticResource Caption}" />
                                    </HorizontalStackLayout>
                                    <Label
                                           Text="{Binding Price, StringFormat='${0:F0}/noche'}"
                                           Style="{StaticResource Price}" FontSize="17" />
                                </VerticalStackLayout>
                                <Button Text="{local:Translate Room_Seleccionar}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RoomSelectionViewModel}}, Path=SelectRoomCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="{StaticResource White}"
                                        HorizontalOptions="Fill"
                                        Margin="0,6,0,0" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Boton Reservar -->
        <Border Grid.Row="1" Padding="16,12"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}"
                IsVisible="{Binding IsRoomSelected}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{local:Translate Room_Seleccionada, StringFormat='Seleccionada: {0}'}"
                       FontFamily="OpenSansSemibold" FontSize="14"
                       HorizontalTextAlignment="Center" />
                <Button Text="{local:Translate Room_Reservar}"
                        Command="{Binding BookCommand}"
                        Style="{StaticResource AccentButton}"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
