<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.PaymentPage"
             x:Name="RootPage"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="24" Spacing="16"
                             VerticalOptions="Center">

            <!-- Payment Info -->
            <Border Padding="20"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="Total a pagar"
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource PrimaryDark}" />
                    <Label Text="{Binding Amount, StringFormat='${0:F0}'}"
                           FontFamily="OpenSansSemibold"
                           FontSize="24"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource PrimaryDark}" />
                    <Label Text="{Binding Description}"
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Payment Providers -->
            <Border Padding="16"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Selecciona un medio de pago" Style="{StaticResource Title}" />
                    <CollectionView ItemsSource="{Binding PaymentProviders}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="PaymentProviders"
                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectPaymentProviderCommand}"
                                            CommandParameter="{Binding .}">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Border BackgroundColor="{StaticResource Surface}"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="{StaticResource Gray100}"
                                                    Padding="12">
                                                <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="10">
                                                    <Image WidthRequest="60" HeightRequest="60" Aspect="AspectFit" VerticalOptions="Center">
                                                        <Image.Source>
                                                            <UriImageSource Uri="{Binding BindingContext.Logo, RelativeSource={RelativeSource TemplatedParent}}" />
                                                        </Image.Source>
                                                    </Image>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding BindingContext.Name, RelativeSource={RelativeSource TemplatedParent}}"
                                                           FontFamily="OpenSansSemibold"
                                                           VerticalOptions="Center" />
                                                    <Label Grid.Column="2"
                                                           Text="✓"
                                                           FontSize="24"
                                                           TextColor="{StaticResource Primary}"
                                                           VerticalOptions="Center"
                                                           IsVisible="{TemplateBinding IsChecked}" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Selected Provider Confirmation -->
            <Border Padding="16,12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray100}"
                    IsVisible="{Binding IsPaymentProviderSelected}">
                <VerticalStackLayout Spacing="8">
                    <Label FontFamily="OpenSansSemibold" FontSize="14"
                           HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Seleccionado: " />
                                <Span Text="{Binding SelectedPaymentProvider.Name}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Button Text="{Binding PayButtonText}"
                            Command="{Binding PayCommand}"
                            Style="{StaticResource AccentButton}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <!-- Go Back Button -->
            <Button Text="Volver"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource OutlineButton}"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
