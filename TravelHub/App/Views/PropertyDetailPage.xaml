<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:converters="clr-namespace:App.Converters"
             x:Class="App.Views.PropertyDetailPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStars" />
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <vm:PropertyDetailViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource Background}">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Galeria de Fotos -->
                <CarouselView ItemsSource="{Binding ImageUrls}"
                              HeightRequest="260"
                              Loop="True"
                              IndicatorView="galleryIndicator">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding .}" Aspect="AspectFill" HeightRequest="260" />
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
                <IndicatorView x:Name="galleryIndicator"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"
                               IndicatorColor="{StaticResource Gray300}"
                               SelectedIndicatorColor="{StaticResource Primary}" />

                <!-- Info Principal -->
                <VerticalStackLayout Padding="16,12" Spacing="8"
                                     BackgroundColor="{StaticResource Surface}">
                    <Label Text="{Binding Property.Name}"
                           Style="{StaticResource Headline}"
                           FontSize="24" />
                    <Label Text="{Binding Property.Address}"
                           Style="{StaticResource Subtitle}" />

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding Property.Rating, Converter={StaticResource RatingToStars}}"
                               TextColor="{StaticResource Star}" FontSize="16" />
                        <Label Text="{Binding Property.Rating, StringFormat='{0:F1}'}"
                               FontFamily="OpenSansSemibold" FontSize="16" />
                        <Label Text="{Binding Property.ReviewCount, StringFormat='({0} resenas)'}"
                               Style="{StaticResource Caption}" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding Property.PricePerNight, StringFormat='Desde ${0:F0} / noche'}"
                           Style="{StaticResource Price}" />
                </VerticalStackLayout>

                <!-- Descripcion -->
                <Border Margin="16,8" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Descripcion" Style="{StaticResource Title}" />
                        <Label Text="{Binding Property.Description}"
                               Style="{StaticResource Subtitle}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Amenidades -->
                <Border Margin="16,4" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Amenidades" Style="{StaticResource Title}" />
                        <Label Text="{Binding AmenityList}"
                               Style="{StaticResource Subtitle}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Mapa Placeholder -->
                <Border Margin="16,4" Padding="0"
                        BackgroundColor="{StaticResource Gray100}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray200}"
                        HeightRequest="180">
                    <Grid>
                        <Label Text="Aquí va el Mapa - Ubicacion"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Style="{StaticResource Subtitle}" />
                    </Grid>
                </Border>

                <!-- Comentarios -->
                <Border Margin="16,8,16,16" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Comentarios" Style="{StaticResource Title}" />
                        <CollectionView ItemsSource="{Binding Reviews}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding AuthorName}"
                                                   FontFamily="OpenSansSemibold" FontSize="14" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}"
                                                   Style="{StaticResource Caption}" />
                                        </Grid>
                                        <Label Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                               TextColor="{StaticResource Star}" FontSize="12" />
                                        <Label Text="{Binding Comment}"
                                               Style="{StaticResource Subtitle}"
                                               LineBreakMode="WordWrap" />
                                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"
                                                 Margin="0,6,0,0" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boton Elegir Habitacion -->
        <Border Grid.Row="1" Padding="16,12"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}">
            <Button Text="Elegir Habitacion"
                    Command="{Binding ChooseRoomCommand}"
                    Style="{StaticResource AccentButton}"
                    HorizontalOptions="Fill" />
        </Border>
    </Grid>
</ContentPage>
