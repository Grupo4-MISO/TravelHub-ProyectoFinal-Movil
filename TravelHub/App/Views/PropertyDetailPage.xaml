<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:App.DTOs"
             xmlns:converters="clr-namespace:App.Converters"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.PropertyDetailPage"
             AutomationId="PropertyDetail_Page"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStars" />
        <converters:IconKeyToGlyphConverter x:Key="IconKeyToGlyph" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource Background}">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">
                <!--<VerticalStackLayout Padding="16,8,16,0" Spacing="6">
                    <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
                    <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>-->

                <!-- Galeria de Fotos -->
                <CarouselView ItemsSource="{Binding ImageUrls}"
                              HeightRequest="260"
                              Loop="True"
                              IndicatorView="galleryIndicator">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding .}" Aspect="AspectFill" HeightRequest="260" />
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
                <IndicatorView x:Name="galleryIndicator"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"
                               IndicatorColor="{StaticResource Gray300}"
                               SelectedIndicatorColor="{StaticResource Primary}" />

                <!-- Info Principal -->
                <VerticalStackLayout Padding="16,12" Spacing="8"
                                     BackgroundColor="{StaticResource Surface}">
                    <Label Text="{Binding Property.Name}"
                           AutomationId="PropertyDetail_PropertyName"
                           Style="{StaticResource Headline}"
                           FontSize="24" />
                    <Label Text="{Binding Property.Address}"
                           Style="{StaticResource Subtitle}" />

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding Property.Rating, Converter={StaticResource RatingToStars}}"
                               TextColor="{StaticResource Star}" FontSize="16" />
                        <Label Text="{Binding Property.Rating, StringFormat='{0:F1}'}"
                               FontFamily="OpenSansSemibold" FontSize="16" />
                            <Label Text="{Binding Property.ReviewCount, StringFormat='({0} reseñas)'}" 
                               Style="{StaticResource Caption}" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding PriceforNight, StringFormat='Desde ${0:F0} / noche'}"
                           AutomationId="PropertyDetail_PropertyPrice"
                           Style="{StaticResource Price}" />
                </VerticalStackLayout>

                <!-- Descripcion -->
                <Border Margin="16,8" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{local:Translate Detail_Descripcion}" Style="{StaticResource Title}" />
                        <Label Text="{Binding Property.Description}"
                               Style="{StaticResource Subtitle}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Amenidades -->
                <Border Margin="16,4" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="{local:Translate Detail_Amenidades}" Style="{StaticResource Title}" />
                        <FlexLayout Wrap="Wrap" 
                                    JustifyContent="Start"
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding Property.Amenities}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="dto:AccommodationDetailAmenityDto">
                                    <Border Padding="10,6"
                                            Margin="0,0,8,8"
                                            BackgroundColor="{StaticResource Background}"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{StaticResource Gray200}">
                                        <HorizontalStackLayout Spacing="6">
                                            <Image Style="{StaticResource IconImageSmall}">
                                                <Image.Source>
                                                    <FontImageSource
                                                        Glyph="{Binding Icon, Converter={StaticResource IconKeyToGlyph}}"
                                                        FontFamily="MaterialSymbols"
                                                        Size="18"
                                                        Color="{StaticResource Primary}" />
                                                </Image.Source>
                                            </Image>
                                            <Label Text="{Binding Name}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Mapa -->
                <Border Margin="16,4" Padding="0"
                         BackgroundColor="{StaticResource Gray100}"
                         StrokeShape="RoundRectangle 12"
                         Stroke="{StaticResource Gray200}"
                         HeightRequest="220">
                    <maps:Map x:Name="PropertyMap"
                              IsShowingUser="False" />
                </Border>

                <!-- Comentarios -->
                <Border Margin="16,8,16,16" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="12">
                         <Label Text="{local:Translate Detail_Comentarios}" Style="{StaticResource Title}" />
                        <Label Text="{Binding ReviewsErrorMessage}"
                               IsVisible="{Binding HasReviewsError}"
                               TextColor="{StaticResource Danger}" />
                        <CollectionView ItemsSource="{Binding Reviews}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding UserName}"
                                                   FontFamily="OpenSansSemibold" FontSize="14" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Date, StringFormat='{0:dd/MM/yyyy}'}"
                                                   Style="{StaticResource Caption}" />
                                        </Grid>
                                        <Label Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                               TextColor="{StaticResource Star}" FontSize="12" />
                                        <Label Text="{Binding Comment}"
                                               Style="{StaticResource Subtitle}"
                                               LineBreakMode="WordWrap" />
                                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}"
                                                 Margin="0,6,0,0" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                 <Label Text="{local:Translate Detail_SinComentarios}"
                                       Style="{StaticResource Subtitle}" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boton Elegir Habitacion -->
        <Border Grid.Row="1" Padding="16,12"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}">
            <Button Text="{local:Translate Detail_ElegirHabitacion}"
                    AutomationId="PropertyDetail_ChooseRoomButton"
                    Command="{Binding ChooseRoomCommand}"
                    Style="{StaticResource AccentButton}"
                    HorizontalOptions="Fill" />
        </Border>

        <!-- ================= LOADER ================= -->
        <Border
            Grid.Row="1"
             IsVisible="{Binding IsBusy}"
             BackgroundColor="#FFFFFF"
             StrokeThickness="0"
             InputTransparent="False">
            <VerticalStackLayout Spacing="5"
             HorizontalOptions="Center"
             VerticalOptions="Center">
                <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
                <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
