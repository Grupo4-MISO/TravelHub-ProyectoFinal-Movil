<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.BookingConfirmedPage"
             x:Name="RootPage"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="24" Spacing="16"
                             VerticalOptions="Center">

            <!-- Icono de exito -->
            <Border WidthRequest="80" HeightRequest="80"
                    BackgroundColor="{StaticResource Success}"
                    StrokeShape="RoundRectangle 40"
                    Stroke="Transparent"
                    HorizontalOptions="Center">
                <Label Text="&#x2713;"
                       TextColor="{StaticResource White}"
                       FontSize="40"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

<Label Text="{local:Translate Confirmed_Titulo}"
       Style="{StaticResource Headline}"
       HorizontalTextAlignment="Center" />

<Label Text="{local:Translate Confirmed_Mensaje}"
       Style="{StaticResource Subtitle}"
       HorizontalTextAlignment="Center" />

            <!-- Codigo de reserva -->
            <Border Padding="20"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="{local:Translate Confirmed_Codigo}"
                       Style="{StaticResource Caption}"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource PrimaryDark}" />
                    <Label Text="{Binding Reservation.Booking.BookingCode}"
                           FontFamily="OpenSansSemibold"
                           FontSize="24"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource PrimaryDark}" />
                </VerticalStackLayout>
            </Border>

            <!-- Detalles -->
            <Border Padding="16"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{local:Translate Confirmed_Detalles}" Style="{StaticResource Title}" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Text="{local:Translate Confirmed_Hotel}" Style="{StaticResource Caption}" />
                        <Label Grid.Column="1" Text="{Binding Reservation.Property.Name}"
                               FontFamily="OpenSansSemibold" FontSize="13" />

                        <Label Grid.Row="1" Text="{local:Translate Confirmed_Habitacion}" Style="{StaticResource Caption}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Reservation.Room.Description}"
                               FontSize="13" />

                        <Label Grid.Row="2" Text="{local:Translate Confirmed_CheckIn}" Style="{StaticResource Caption}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Reservation.CheckIn, StringFormat='{0:dd/MM/yyyy}'}"
                               FontSize="13" />

                        <Label Grid.Row="3" Text="{local:Translate Confirmed_CheckOut}" Style="{StaticResource Caption}" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding Reservation.CheckOut, StringFormat='{0:dd/MM/yyyy}'}"
                               FontSize="13" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{local:Translate Confirmed_Total}" FontFamily="OpenSansSemibold" FontSize="16" />
                        <Label Grid.Column="1"
                               Text="{Binding Reservation.TotalPrice, StringFormat='${0:F0}'}"
                               Style="{StaticResource Price}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Padding="16"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{local:Translate Confirmed_MediosPago}" Style="{StaticResource Title}" />
                    <CollectionView ItemsSource="{Binding PaymentProviders}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{StaticResource Surface}"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="{StaticResource Gray100}"
                                        Padding="12">
                                    <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="10">
                                        <Image 
                                               WidthRequest="60"
                                               HeightRequest="60"
                                               Aspect="AspectFit"
                                               VerticalOptions="Center">
                                            <Image.Source>
                                                <UriImageSource Uri="{Binding Logo}" />
                                            </Image.Source>
                                        </Image>
                                        <Label Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center" />
                                        <Button Grid.Column="2"
                                                Text="OK"
                                                Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectPaymentProviderCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Primary}"
                                                TextColor="{StaticResource White}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Padding="16,12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray100}"
                    IsVisible="{Binding IsPaymentProviderSelected}">
                <VerticalStackLayout Spacing="8">
                    <Label FontFamily="OpenSansSemibold" FontSize="14"
                           HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{local:Translate Confirmed_Seleccionado}" />
                                <Span Text=" " />
                                <Span Text="{Binding SelectedPaymentProvider.Name}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Button Text="{Binding PayButtonText}"
                            Command="{Binding PayCommand}"
                            Style="{StaticResource AccentButton}"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <!-- Botones -->
<Button Text="{local:Translate Confirmed_IrInicio}"
        Command="{Binding GoHomeCommand}"
        HorizontalOptions="Fill" />

<Button Text="{local:Translate Confirmed_VerReservas}"
        Command="{Binding ViewBookingsCommand}"
        Style="{StaticResource OutlineButton}"
        HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
