<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:App.ViewModels"
    x:Class="App.Views.SettingsPage"
    AutomationId="Settings_Page"
    Title="Configuración">



    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">
            
            <!-- Header -->
            <Label x:Name="SettingsHeaderLabel"
                   Text="Accesibilidad" 
                   Style="{DynamicResource Headline}" 
                   HorizontalOptions="Center"
                    SemanticProperties.Description="Settings_Header" />

            <!-- Language -->
            <Frame Padding="15" CornerRadius="10" BackgroundColor="{DynamicResource Surface}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="LanguageLabel" Text="Seleccionar idioma" Style="{DynamicResource Title}" />
                    <Picker x:Name="LanguagePicker"
                            AutomationId="Settings_LanguagePicker"
                            SelectedIndexChanged="OnLanguageChanged" />
                </VerticalStackLayout>
            </Frame>
             
            <!-- Dark Mode -->
            <Frame Padding="15" CornerRadius="10" BackgroundColor="{DynamicResource Surface}">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label x:Name="DarkModeLabel"
                           Text="Modo Oscuro" 
                           Style="{DynamicResource Title}" 
                           HorizontalOptions="StartAndExpand" />
                    <Switch IsToggled="{Binding DarkModeEnabled}" 
                             AutomationId="Settings_DarkModeSwitch"
                             SemanticProperties.Description="Settings_DarkModeSwitch"
                             OnColor="{DynamicResource Primary}" />
                </HorizontalStackLayout>
            </Frame>
            
            <!-- Color Blindness Mode -->
            <Frame Padding="15" CornerRadius="10" BackgroundColor="{DynamicResource Surface}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="ColorBlindnessLabel" Text="Modo Daltonismo" Style="{DynamicResource Title}" />
                    <Picker x:Name="ColorBlindnessPicker"
                             Title="Seleccionar modo"
                             AutomationId="Settings_ColorBlindnessPicker"
                             SemanticProperties.Description="Settings_ColorBlindnessPicker"
                             ItemsSource="{Binding ColorBlindnessOptions}"
                             SelectedItem="{Binding SelectedColorBlindnessOption}" />
                </VerticalStackLayout>
            </Frame>
             
            <!-- Text Size -->
            <Frame Padding="15" CornerRadius="10" BackgroundColor="{DynamicResource Surface}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="TextSizeLabel" Text="Tamaño de Texto" Style="{DynamicResource Title}" />
                    <Picker x:Name="TextSizePicker"
                            Title="Seleccionar tamaño"
                            AutomationId="Settings_TextSizePicker"
                            ItemsSource="{Binding TextSizeOptions}"
                            SelectedItem="{Binding TextSizeScale}" />
                </VerticalStackLayout>
            </Frame>
             
            <!-- Restore Defaults Button -->
            <Button x:Name="RestoreDefaultsButton"
                    Text="Restaurar Valores Predeterminados" 
                    AutomationId="Settings_RestoreDefaultsButton"
                    Command="{Binding RestoreDefaultsCommand}" 
                    Style="{DynamicResource OutlineButton}"
                    Margin="0,20,0,0" />
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
