<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:App.Resources.Styles"
             xmlns:behaviors="clr-namespace:App.Behaviors"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.TravelerDataPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource Background}">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Info de la reserva -->
                <Border Padding="14"
                        BackgroundColor="WhiteSmoke"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Image Source="{Binding Room.ImageUrl}"
                               WidthRequest="70" HeightRequest="70"
                               Aspect="AspectFill" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Property.Name}"
                                   FontFamily="OpenSansSemibold" FontSize="15"
                                   TextColor="{StaticResource PrimaryDark}" />
                            <Label Text="{Binding Room.Description}"
                                   FontSize="13"
                                   TextColor="{StaticResource PrimaryDark}" />
<Label Text="{Binding Room.Price, StringFormat={local:Translate Traveler_PorNoche}}"
       FontFamily="OpenSansSemibold" FontSize="13"
       TextColor="{StaticResource Primary}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Formulario -->
                <Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{local:Translate Traveler_Datos}" Style="{StaticResource Title}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Traveler_Nombre}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Traveler_NombrePlaceholder}"
       Text="{Binding FirstName}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Traveler_Apellido}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
<Entry Placeholder="{local:Translate Traveler_ApellidoPlaceholder}"
       Text="{Binding LastName}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Traveler_Email}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Image Grid.Column="0" 
                                           WidthRequest="20" 
                                           HeightRequest="20"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource
                                                Glyph="{x:Static icons:Icons.Email}"
                                                FontFamily="MaterialSymbols"
                                                Size="20"
                                                Color="{StaticResource Gray400}" />
                                        </Image.Source>
                                    </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Traveler_EmailPlaceholder}"
       Text="{Binding Email}"
       Keyboard="Email"
       ClearButtonVisibility="WhileEditing" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Traveler_Telefono}" Style="{StaticResource Caption}" />
                            <Border Padding="12,8"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
                                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                    <!-- Bandera del país -->
                                    <Label Grid.Column="0"
                                           Text="{Binding CountryFlag}"
                                           FontSize="24"
                                           VerticalOptions="Center" />

                                    <!-- Código de país -->
                                    <Label Grid.Column="1"
                                           Text="{Binding PhoneCode}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />

                                    <!-- Campo de entrada del número -->
<Entry Grid.Column="2"
       Placeholder="{local:Translate Traveler_TelefonoPlaceholder}"
       Text="{Binding PhoneNumber}"
       Keyboard="Telephone">
                                        <!--<Entry.Behaviors>
                                            <behaviors:PhoneNumberFormattingBehavior />
                                        </Entry.Behaviors>-->
                                    </Entry>
                                </Grid>
                            </Border>
                            <Label Text="{Binding FullPhoneNumber, StringFormat='Teléfono completo: {0}'}"
                                   Style="{StaticResource Caption}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}"
                                   Margin="4,2,0,0" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{local:Translate Traveler_Documento}" Style="{StaticResource Caption}" />
                            <Border Padding="12,0"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Image Grid.Column="0" 
                                           WidthRequest="20" 
                                           HeightRequest="20"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource
                                                Glyph="{x:Static icons:Icons.Documento}"
                                                FontFamily="MaterialSymbols"
                                                Size="20"
                                                Color="{StaticResource Gray400}" />
                                        </Image.Source>
                                    </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Traveler_DocumentoPlaceholder}"
       Text="{Binding DocumentNumber}"
       Keyboard="Numeric"
       ClearButtonVisibility="WhileEditing" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Información adicional -->
                        <Border Padding="12"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Margin="0,8,0,0">
                            <HorizontalStackLayout Spacing="8">
                                <Image WidthRequest="20" HeightRequest="20" VerticalOptions="Start">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Info}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Primary}" />
                                    </Image.Source>
                                </Image>
<Label Text="{local:Translate Traveler_Asegurate}"
       Style="{StaticResource Caption}"
       FontSize="12"
       LineBreakMode="WordWrap"
       VerticalOptions="Center"
       FlexLayout.Grow="1" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boton Continuar -->
        <Border Grid.Row="1" Padding="16,12"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}">
            <Grid>
<Button Text="{local:Translate Traveler_Continuar}"
        IsVisible="{Binding ShowContinueButton}"
        Command="{Binding ContinueCommand}"
        Style="{StaticResource AccentButton}"
        HorizontalOptions="Fill" />
<Button Text="{local:Translate Traveler_Actualizar}"
        IsVisible="{Binding ShowUpdateButton}"
        Command="{Binding UpdateTravelerCommand}"
        Style="{StaticResource UpdateButton}"
        HorizontalOptions="Fill" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
