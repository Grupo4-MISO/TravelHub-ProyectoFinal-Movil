<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:dto="clr-namespace:App.DTOs"
             xmlns:converters="clr-namespace:App.Converters"
             xmlns:icons="clr-namespace:App.Resources.Styles"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.BookingDetailsPage"
             x:DataType="vm:BookingDetailsViewModel"
             Title="{local:Translate Details_Titulo}">

    <ContentPage.Resources>
        <converters:IconKeyToGlyphConverter x:Key="IconKeyToGlyph" />
        <converters:TruncateTextConverter x:Key="TruncateText" MaxLength="15" Suffix="..." />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" BackgroundColor="{StaticResource Background}">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- CA1 & CA2: Información General de la Reserva -->
                <Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Booking.PublicId, StringFormat={local:Translate Details_ReservaNum}}"
                               Style="{StaticResource Title}" />
                            <Border Grid.Column="1" Grid.Row="0"
                                StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                Padding="8,3">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Booking.Estado}" Value="pendiente">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Booking.Estado}" Value="confirmada">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Booking.Estado}" Value="completada">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding Booking.Estado}"
                                       VerticalTextAlignment="Center"
                                       TextColor="{StaticResource White}"
                                       FontSize="11" />
                            </Border>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />

                        <!-- Fechas -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout>
                                <Label Text="{local:Translate Details_CheckIn}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding Booking.CheckIn, StringFormat='{0:dd/MM/yyyy}'}"
                                       FontFamily="OpenSansSemibold" FontSize="16" />
                                <Label Text="{Binding Booking.CheckIn, StringFormat='{0:HH:mm}'}"
                                       Style="{StaticResource Subtitle}" FontSize="12" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{local:Translate Details_CheckOut}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding Booking.CheckOut, StringFormat='{0:dd/MM/yyyy}'}"
                                       FontFamily="OpenSansSemibold" FontSize="16" />
                                <Label Text="{Binding Booking.CheckOut, StringFormat='{0:HH:mm}'}"
                                       Style="{StaticResource Subtitle}" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Huéspedes y Habitación -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                            <VerticalStackLayout>
                                <Label Text="{local:Translate Details_Huespedes}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding Room.Capacity, StringFormat={local:Translate Details_Personas}}"
                                       FontFamily="OpenSansSemibold" FontSize="15" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{local:Translate Details_Habitacion}" Style="{StaticResource Caption}" />
                                <Label Text="{Binding Room.Description}"
                                       FontFamily="OpenSansSemibold" FontSize="15" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- CA3: Información del Hotel -->
                <Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                        <Image Source="{Binding ImageUrl}"
                               WidthRequest="80" HeightRequest="80"
                               Aspect="AspectFill">
                            <Image.Clip>
                                <RoundRectangleGeometry CornerRadius="8" Rect="0,0,80,80" />
                            </Image.Clip>
                        </Image>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding Property.Name}"
                                   FontFamily="OpenSansSemibold" FontSize="17" />
                            <Label Text="{Binding Property.Address}" 
                                   Style="{StaticResource Subtitle}" FontSize="13" />
                            <Label Text="{Binding Property.City}"
                                   Style="{StaticResource Subtitle}" FontSize="13" />
                            <!--<HorizontalStackLayout Spacing="4" Margin="0,2,0,0">
                                <Image Style="{StaticResource IconImageSmall}">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Telefono}"
                                            FontFamily="MaterialSymbols"
                                            Size="16"
                                            Color="{StaticResource TextSecondary}" />
                                    </Image.Source>
                                </Image>
                                <Label Text="{Binding Hotel.Phone}"
                                       Style="{StaticResource Subtitle}" FontSize="12" />
                            </HorizontalStackLayout>-->
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Amenidades -->
                <Border Margin="16,4" Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{local:Translate Detail_Amenidades}" Style="{StaticResource Title}" />
                        <FlexLayout Wrap="Wrap" 
                                    JustifyContent="Start"
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding Property.Amenities}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="dto:AccommodationDetailAmenityDto">
                                    <Border Padding="10,6"
                                            Margin="0,0,8,8"
                                            BackgroundColor="{StaticResource Background}"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{StaticResource Gray200}">
                                        <HorizontalStackLayout Spacing="6">
                                            <Image Style="{StaticResource IconImageSmall}">
                                                <Image.Source>
                                                    <FontImageSource
                                                        Glyph="{Binding Icon, Converter={StaticResource IconKeyToGlyph}}"
                                                        FontFamily="MaterialSymbols"
                                                        Size="18"
                                                        Color="{StaticResource Primary}" />
                                                </Image.Source>
                                            </Image>
                                            <Label Text="{Binding Name}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- CA5: Información Económica -->
                <Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{local:Translate Details_InfoPago}" Style="{StaticResource Title}" />

                        <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{local:Translate Details_PrecioNoche}"
                               Style="{StaticResource Subtitle}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Room.Price, StringFormat='{0:C}'}"
                                   FontFamily="OpenSansSemibold" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Nights, StringFormat='x {0} noche(s)'}"
                                   Style="{StaticResource Subtitle}" />
                            <Label Grid.Column="1"
                                   Text="{Binding SubTotal, StringFormat='{0:C}'}"
                                   FontFamily="OpenSansSemibold" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{local:Translate Details_Impuestos}"
                                   Style="{StaticResource Subtitle}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Taxes, StringFormat='{0:C}'}"
                                   FontFamily="OpenSansSemibold" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{local:Translate Details_Total}"
                                   FontFamily="OpenSansSemibold" FontSize="18" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='{0:C}'}"
                                   Style="{StaticResource Price}" />
                        </Grid>

                            <Label Text="{Binding Currency, StringFormat={local:Translate Details_Moneda}}"
                                    Style="{StaticResource Caption}" />

                        <Border Padding="12,8"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Margin="0,4,0,0">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{local:Translate Details_EstadoPago}"
                                       Style="{StaticResource Caption}" FontSize="12" />
                                <Label Text="{Binding PaymentInfo}"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Success}"
                                       FontSize="14" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- CA6: Descarga de Documentos -->
                <!--<Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{local:Translate Details_Documentos}" Style="{StaticResource Title}" />

                        <Button Command="{Binding DownloadVoucherCommand}"
                                Style="{StaticResource OutlineButton}"
                                HorizontalOptions="Fill">
                            <Button.ImageSource>
                                <FontImageSource
                                    Glyph="{x:Static icons:Icons.Voucher}"
                                    FontFamily="MaterialSymbols"
                                    Size="20"
                                    Color="{StaticResource Primary}" />
                            </Button.ImageSource>
                            <Button.Text>Descargar Voucher</Button.Text>
                        </Button>

                        <Button Command="{Binding DownloadConfirmationCommand}"
                                Style="{StaticResource OutlineButton}"
                                HorizontalOptions="Fill">
                            <Button.ImageSource>
                                <FontImageSource
                                    Glyph="{x:Static icons:Icons.Confirmacion}"
                                    FontFamily="MaterialSymbols"
                                    Size="20"
                                    Color="{StaticResource Primary}" />
                            </Button.ImageSource>
                            <Button.Text>{local:Translate Details_DescargarConfirmacion}</Button.Text>
                        </Button>

                        <Button Command="{Binding DownloadInvoiceCommand}"
                                Style="{StaticResource OutlineButton}"
                                HorizontalOptions="Fill"
                                IsVisible="{Binding HasInvoice}">
                            <Button.ImageSource>
                                <FontImageSource
                                    Glyph="{x:Static icons:Icons.Factura}"
                                    FontFamily="MaterialSymbols"
                                    Size="20"
                                    Color="{StaticResource Primary}" />
                            </Button.ImageSource>
                            <Button.Text>{local:Translate Details_DescargarFactura}</Button.Text>
                        </Button>
                    </VerticalStackLayout>
                </Border>-->

                <!-- Contacto con el Hotel -->
                <Border Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{local:Translate Details_ContactarHotel}" Style="{StaticResource Title}" />

                        <!--<Button Command="{Binding CallHotelCommand}"
                                Style="{StaticResource OutlineButton}"
                                HorizontalOptions="Fill">
                            <Button.ImageSource>
                                <FontImageSource
                                    Glyph="{x:Static icons:Icons.Llamar}"
                                    FontFamily="MaterialSymbols"
                                    Size="20"
                                    Color="{StaticResource Primary}" />
                            </Button.ImageSource>
                            <Button.Text>
                                <Binding Path="Hotel.Phone" StringFormat="{local:Translate Details_Llamar}" />
                            </Button.Text>
                        </Button>-->

                        <!--<Button Command="{Binding EmailHotelCommand}"
                                Style="{StaticResource OutlineButton}"
                                HorizontalOptions="Fill">
                            <Button.ImageSource>
                                <FontImageSource
                                    Glyph="{x:Static icons:Icons.Email}"
                                    FontFamily="MaterialSymbols"
                                    Size="20"
                                    Color="{StaticResource Primary}" />
                            </Button.ImageSource>
                            <Button.Text>
                                <MultiBinding StringFormat="{local:Translate Details_Email}">
                                    <Binding Path="Hotel.Email" Converter="{StaticResource TruncateText}" ConverterParameter="15" />
                                </MultiBinding>
                            </Button.Text>
                        </Button>-->

                        <Border Padding="12"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}">
                            <HorizontalStackLayout Spacing="8">
                                <Image Style="{StaticResource IconImageSmall}">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Ubicacion}"
                                            FontFamily="MaterialSymbols"
                                            Size="18"
                                            Color="{StaticResource Primary}" />
                                    </Image.Source>
                                </Image>
                                <VerticalStackLayout Spacing="4">
                                <Label Text="{local:Translate Details_Direccion}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14" />
                                    <Label Text="{Binding Property.Address}"
                                           Style="{StaticResource Subtitle}" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- CA7: Opciones de Gestión -->
        <Border Grid.Row="1" 
                Padding="16,12"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray100}">
            <!--<Grid ColumnDefinitions="*,*" ColumnSpacing="12">-->
            <!--<Button Grid.Column="0"
                    Text="{local:Translate Details_Modificar}"
                    Command="{Binding ModifyBookingCommand}"
                    Style="{StaticResource OutlineButton}"
                    IsVisible="{Binding CanModify}"
                    HorizontalOptions="Fill" />-->
            <Button Grid.Column="1"
                    Text="{local:Translate Details_Cancelar}"
                    Command="{Binding CancelBookingCommand}"
                    Style="{StaticResource OutlineButton}"
                    TextColor="{StaticResource Error}"
                    BorderColor="{StaticResource Error}"
                    IsVisible="{Binding CanCancel}"
                    HorizontalOptions="Fill" />
            <!--</Grid>-->
        </Border>
    </Grid>
</ContentPage>