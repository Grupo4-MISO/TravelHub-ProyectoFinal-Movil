<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:views="clr-namespace:App.Views"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.ActiveBookingsPage"
             x:Name="activeBookingsPage"
             AutomationId="ActiveBookings_Page"
             Title="{Binding Title}"
             IconImageSource="ic_reserve.png"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Background}" RowSpacing="10">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,14" BackgroundColor="{StaticResource Primary}">
<Label Text="{local:Translate Bookings_Titulo}"
       TextColor="{StaticResource White}"
       FontFamily="OpenSansSemibold"
       FontSize="18" />
        </Grid>

        <RefreshView Grid.Row="1"
                     AutomationId="ActiveBookings_RefreshView"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView AutomationId="ActiveBookings_BookingsList"
                            ItemsSource="{Binding Reservations}"
                            Margin="20,12">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource Surface}"
                                StrokeShape="RoundRectangle 14"
                                Stroke="{StaticResource Gray100}"
                                Margin="10,0"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="#18000000" Offset="0,2" Radius="8" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveBookingsViewModel}}, Path=BookingSelectedCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                             <VerticalStackLayout>
                                 <Image Source="{Binding HotelImage}"
                                        Aspect="AspectFill"
                                        HeightRequest="140" />
                                 <VerticalStackLayout Padding="14" Spacing="6">
                                    <Label Text="{Binding HotelName}"
                                                FontFamily="OpenSansSemibold" FontSize="16" />
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Label Grid.Column="0" Grid.Row="0" Text="{Binding HotelCity}" Style="{StaticResource Caption}" />

                                        <Label Grid.Column="0" Grid.Row="1" Text="{Binding BookingCode}" Style="{StaticResource Subtitle}" />
                                        <Border Grid.Column="1" Grid.Row="0"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="8,3">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="pendiente">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="confirmada">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="completada">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Status}"
                                                   VerticalTextAlignment="Center"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="11" />
                                        </Border>
                                     </Grid>
                                     

                                    <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                        <VerticalStackLayout>
                                            <Label Text="{local:Translate Bookings_CheckIn}" Style="{StaticResource Caption}" />
                                            <Label Text="{Binding CheckIn, StringFormat='{0:dd MMM yyyy}'}"
                                                   FontFamily="OpenSansSemibold" FontSize="13" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="{local:Translate Bookings_CheckOut}" Style="{StaticResource Caption}" />
                                            <Label Text="{Binding CheckOut, StringFormat='{0:dd MMM yyyy}'}"
                                                   FontFamily="OpenSansSemibold" FontSize="13" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                        <Label Text="{Binding BookingCode}"
                                               Style="{StaticResource Caption}"
                                               VerticalTextAlignment="Center" />
                                    <!--<Button Grid.Column="1" Text="Hacer Check-in"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveBookingsViewModel}}, Path=CheckInCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Padding="12,6" FontSize="12"
                                                    MinimumHeightRequest="36" />-->
                                    <Button Grid.Column="1" Text="{local:Translate Bookings_HacerCheckIn}"
                                            IsVisible="{Binding CanCheckIn}"
                                            Command="{Binding BindingContext.CheckInCommand, Source={x:Reference activeBookingsPage}}"
                                            CommandParameter="{Binding .}"
                                            Padding="12,6" FontSize="12"
                                            MinimumHeightRequest="36" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Padding="40">
<Label Text="{local:Translate Bookings_SinReservas}"
       Style="{StaticResource SubHeadline}"
       HorizontalTextAlignment="Center" />
<Label Text="{local:Translate Bookings_BuscaViaje}"
       Style="{StaticResource Subtitle}"
       HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
        <!-- ================= LOADER ================= -->
        <Border
                Grid.Row="1"
                 IsVisible="{Binding IsRefreshing}"
                 BackgroundColor="#FFFFFF"
                 StrokeThickness="0"
                 InputTransparent="False">
            <VerticalStackLayout Spacing="5"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">
                <ActivityIndicator IsVisible="{Binding IsRefreshing}" IsRunning="{Binding IsRefreshing}" Color="{StaticResource Primary}" />
                <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
