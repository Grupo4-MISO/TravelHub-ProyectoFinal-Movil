<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:controls="clr-namespace:App.Controls"
             xmlns:converters="clr-namespace:App.Converters"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.HomePage"
             AutomationId="Home_Page"
             IconImageSource="ic_search.png"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStars" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- TopBar -->
        <controls:TopBar Grid.Row="0" />

        <ScrollView Grid.Row="1" BackgroundColor="{StaticResource Background}">
            <VerticalStackLayout Spacing="0">
                
                <!-- Carousel Promocional -->
                <CarouselView ItemsSource="{Binding PromotionalImages}"
                              AutomationId="Home_PromoCarousel"
                              HeightRequest="200"
                              Loop="True"
                              IndicatorView="promoIndicator">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image
                                       Aspect="AspectFill"
                                       HeightRequest="200" >
                                    <Image.Source>
                                        <UriImageSource Uri="{Binding .}" 
                                                CachingEnabled="True" 
                                                CacheValidity="1:00:00:00" />
                                    </Image.Source>
                                </Image>
                                <BoxView Color="#40000000" />
                            </Grid>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
                <IndicatorView x:Name="promoIndicator"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"
                               IndicatorColor="{StaticResource Gray300}"
                               SelectedIndicatorColor="{StaticResource Primary}" />

                <!-- Motor de Busqueda -->
                <Border Margin="16,16,16,0"
                        Padding="16"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource Gray100}">
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{local:Translate Home_BuscarHospedaje}"
                               Style="{StaticResource SubHeadline}" />

                        <!-- Ciudad -->
                        <Border Padding="12,4"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Picker Title="{local:Translate Home_CiudadDestino}"
                                     AutomationId="Home_CityPicker"
                                     SelectedIndex="0"
                                    ItemsSource="{Binding PopularCities}"
                                    SelectedItem="{Binding SelectedCity}" />
                        </Border>

                        <!-- Fechas -->
                        <Grid ColumnDefinitions="*,16,*">
                            <Border Padding="12,4"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
                                <VerticalStackLayout>
                                    <Label Text="{local:Translate Home_CheckIn}" Style="{StaticResource Caption}" />
                                    <DatePicker Date="{Binding CheckInDate}"
                                                AutomationId="Home_CheckInDate"
                                                MinimumDate="{Binding MinDate}"
                                                Format="dd/MM/yyyy" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" Padding="12,4"
                                    BackgroundColor="{StaticResource Background}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource Gray200}">
                                <VerticalStackLayout>
                                    <Label Text="{local:Translate Home_CheckOut}" Style="{StaticResource Caption}" />
                                    <DatePicker Date="{Binding CheckOutDate}"
                                                AutomationId="Home_CheckOutDate"
                                                MinimumDate="{Binding CheckInDate}"
                                                Format="dd/MM/yyyy" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Resumen Personas y habitaciones -->
                        <Border Padding="12,4"
                                AutomationId="Home_GuestConfigToggle"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleGuestConfigCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="auto, *, auto" ColumnSpacing="10">
                                <Image Grid.Column="0" Source="ic_account.png" WidthRequest="20" />
                                <Label Grid.Column="1" Text="{Binding GuestSummary}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="{Binding IsGuestConfigVisible, StringFormat='{0}'}"
                                       IsVisible="False" />
                            </Grid>
                        </Border>

                        <!-- Adultos / Ninos / Habitaciones -->
                        <Grid ColumnDefinitions="*"
                              RowDefinitions="auto,auto,auto"
                              RowSpacing="10"
                              ColumnSpacing="10"
                              IsVisible="{Binding IsGuestConfigVisible}">
                            <!-- Adultos -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,auto">
                                <Label Grid.Column="0" Text="{local:Translate Home_Adultos}" Style="{StaticResource Caption}" 
                                       HorizontalTextAlignment="Start" VerticalTextAlignment="Center" />
                                <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" HorizontalOptions="Center">
                                    <Button Text="-" Command="{Binding DecrementAdultsCommand}"
                                            AutomationId="Home_AdultsDecrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                    <Label Grid.Column="1" Text="{Binding Adults}"
                                           AutomationId="Home_AdultsValue"
                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                           FontSize="16" FontFamily="OpenSansSemibold"
                                           WidthRequest="36" />
                                    <Button Grid.Column="2" Text="+" Command="{Binding IncrementAdultsCommand}"
                                            AutomationId="Home_AdultsIncrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                </Grid>
                            </Grid>

                            <!-- Ninos -->
                            <Grid Grid.Row="1" ColumnDefinitions="*,auto">
                                <Label Grid.Column="0" Text="{local:Translate Home_Ninos}" Style="{StaticResource Caption}" 
                                         HorizontalTextAlignment="Start" VerticalTextAlignment="Center" />
                                <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" HorizontalOptions="Center">
                                    <Button Text="-" Command="{Binding DecrementChildrenCommand}"
                                            AutomationId="Home_ChildrenDecrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                    <Label Grid.Column="1" Text="{Binding Children}"
                                           AutomationId="Home_ChildrenValue"
                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                           FontSize="16" FontFamily="OpenSansSemibold"
                                           WidthRequest="36" />
                                    <Button Grid.Column="2" Text="+" Command="{Binding IncrementChildrenCommand}"
                                            AutomationId="Home_ChildrenIncrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                </Grid>
                            </Grid>

                            <!-- Habitaciones -->
                            <Grid Grid.Row="2" ColumnDefinitions="*,auto">
                                <Label Grid.Column="0" Text="{local:Translate Home_Habitaciones}" Style="{StaticResource Caption}" 
                                         HorizontalTextAlignment="Start" VerticalTextAlignment="Center" />
                                <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" HorizontalOptions="Center">
                                    <Button Text="-" Command="{Binding DecrementRoomsCommand}"
                                            AutomationId="Home_RoomsDecrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                    <Label Grid.Column="1" Text="{Binding Rooms}"
                                           AutomationId="Home_RoomsValue"
                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                           FontSize="16" FontFamily="OpenSansSemibold"
                                           WidthRequest="36" />
                                    <Button Grid.Column="2" Text="+" Command="{Binding IncrementRoomsCommand}"
                                            AutomationId="Home_RoomsIncrement"
                                            WidthRequest="36" HeightRequest="36"
                                            MaximumWidthRequest="36"
                                            MaximumHeightRequest="36"
                                            BackgroundColor="WhiteSmoke"
                                            TextColor="Black"
                                            Padding="0" CornerRadius="18" FontSize="18" />
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- Boton Buscar -->
                        <Button Text="{local:Translate Home_Buscar}"
                                AutomationId="Home_SearchButton"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Border>

                <!-- Propiedades Recomendadas -->
                <!--<Label Text="Recomendados"
                       Style="{StaticResource SubHeadline}"
                       Margin="16,20,16,8" />

                <CollectionView ItemsSource="{Binding FeaturedProperties}"
