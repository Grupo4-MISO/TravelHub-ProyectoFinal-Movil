<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:App.Resources.Styles"
             xmlns:behaviors="clr-namespace:App.Behaviors"
             xmlns:local="clr-namespace:App.MarkupExtensions"
             x:Class="App.Views.AccountRegisterPage"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">
    
    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="32" Spacing="20"
                             VerticalOptions="Center">

            <!-- Logo / Titulo -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,20,0,20">
                <Image Source="travelhub.png" 
                       Aspect="AspectFit"
                       HeightRequest="40" />
                <!--<Label Text="Crear Cuenta"
                       Style="{StaticResource Headline}"
                       FontSize="28"
                       HorizontalTextAlignment="Center" />-->
<Label Text="{local:Translate Register_Titulo}"
       Style="{StaticResource Subtitle}"
       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Formulario -->
            <Border Padding="20"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource Gray100}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,3" Radius="10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    
                    <!-- Numero de Documento -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Documento}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Documento}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_DocumentoPlaceholder}"
       Text="{Binding DocumentNumber}"
       Keyboard="Numeric"
       MaxLength="20"
       ClearButtonVisibility="WhileEditing" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Genero -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Genero}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Usuario}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Picker Grid.Column="1"
        Title="{local:Translate Register_GeneroTitle}"
        SelectedItem="{Binding Gender}">
    <Picker.Items>
        <x:String>{local:Translate Register_Female}</x:String>
        <x:String>{local:Translate Register_Male}</x:String>
        <x:String>{local:Translate Register_Other}</x:String>
    </Picker.Items>
</Picker>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Nombre}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Persona}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_NombrePlaceholder}"
       Text="{Binding FirstName}"
       ClearButtonVisibility="WhileEditing" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Apellido -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Apellido}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Persona}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_ApellidoPlaceholder}"
       Text="{Binding LastName}"
       ClearButtonVisibility="WhileEditing" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Email}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Email}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_EmailPlaceholder}"
       Text="{Binding Email}"
       Keyboard="Email"
       ClearButtonVisibility="WhileEditing" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Telefono -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Telefono}" Style="{StaticResource Caption}" />
                        <Border Padding="12,8"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding CountryFlag}"
                                       FontSize="20"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding PhoneCode}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" />
<Entry Grid.Column="2"
       Placeholder="{local:Translate Register_TelefonoPlaceholder}"
       Text="{Binding PhoneNumber}"
       Keyboard="Telephone"
       MaxLength="20"
       ClearButtonVisibility="WhileEditing">
                                    <!--<Entry.Behaviors>
                                        <behaviors:PhoneNumberFormattingBehavior />
                                    </Entry.Behaviors>-->
                                </Entry>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_Contrasena}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Llave}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_ContrasenaPlaceholder}"
       Text="{Binding Password}"
       IsPassword="True" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirmar Contrasena -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{local:Translate Register_ConfirmarContrasena}" Style="{StaticResource Caption}" />
                        <Border Padding="12,0"
                                BackgroundColor="{StaticResource Background}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Image Grid.Column="0" 
                                       WidthRequest="20" 
                                       HeightRequest="20"
                                       VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource
                                            Glyph="{x:Static icons:Icons.Llave}"
                                            FontFamily="MaterialSymbols"
                                            Size="20"
                                            Color="{StaticResource Gray400}" />
                                    </Image.Source>
                                </Image>
<Entry Grid.Column="1"
       Placeholder="{local:Translate Register_ConfirmarPlaceholder}"
       Text="{Binding ConfirmPassword}"
       IsPassword="True" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Terminos y condiciones -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,4,0,0">
                        <CheckBox Grid.Column="0" 
                                  IsChecked="{Binding AcceptTerms}"
                                  VerticalOptions="Start" />
                        <Label Grid.Column="1" 
                               VerticalTextAlignment="Center">
<Label.FormattedText>
    <FormattedString>
        <Span Text="{local:Translate Register_Acepto}" 
              Style="{StaticResource Caption}" />
         <Span Text="{local:Translate Register_Terminos}" 
               TextColor="{StaticResource Primary}"
               FontFamily="OpenSansSemibold"
               FontSize="13"
               TextDecorations="Underline" />
     </FormattedString>
 </Label.FormattedText>
                         </Label>
                    </Grid>

                    <!-- Boton Registrarse -->
<Button Text="{local:Translate Register_Registrarse}"
        Command="{Binding RegisterCommand}"
        HorizontalOptions="Fill"
        Margin="0,8,0,0" />

                    <!-- Link a Login -->
                    <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
<Label Text="{local:Translate Register_YaTienesCuenta}"
       Style="{StaticResource Caption}"
       VerticalTextAlignment="Center" />
<Label Text="{local:Translate Register_IniciaSesion}"
       TextColor="{StaticResource Primary}"
       FontFamily="OpenSansSemibold"
       FontSize="13"
       VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
