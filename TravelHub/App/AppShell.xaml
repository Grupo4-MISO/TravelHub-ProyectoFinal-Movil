<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:App.Views"
    xmlns:icons="clr-namespace:App.Resources.Styles"
    Title="TravelHub">

    <TabBar>
        <ShellContent
            Title="Buscar"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="home">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="{x:Static icons:Icons.Buscar}"
                    FontFamily="MaterialSymbols"
                    Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Reservas"
            ContentTemplate="{DataTemplate views:ActiveBookingsPage}"
            Route="bookings">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="{x:Static icons:Icons.Reservas}"
                    FontFamily="MaterialSymbols"
                    Size="24" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent
            Title="Mi Cuenta"
            ContentTemplate="{DataTemplate views:AccountPage}"
            Route="account">
            <ShellContent.Icon>
                <FontImageSource
                    Glyph="{x:Static icons:Icons.Cuenta}"
                    FontFamily="MaterialSymbols"
                    Size="24" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
